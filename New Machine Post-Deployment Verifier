REM === New Machine Post-Deployment Verifier (Win10/11) ===
REM Bash Bunny: HID + STORAGE
ATTACKMODE HID STORAGE

LED AMBER
DELAY 8000

REM Open Run
LED BLUE
GUI r
DELAY 400

REM Launch PowerShell as Admin (best results)
STRING powershell
DELAY 200
CTRL SHIFT ENTER
DELAY 2200

REM Accept UAC (US keyboard). Retry helps on slow focus.
LED PURPLE
ALT y
DELAY 1200
ALT y
DELAY 800

LED YELLOW

REM ---- PowerShell Verifier + Logging + Copy to Bunny ----
STRING powershell -NoProfile -ExecutionPolicy Bypass -Command "$ErrorActionPreference='Continue'; $ts=Get-Date -Format 'yyyyMMdd_HHmmss'; $hn=$env:COMPUTERNAME; $work=Join-Path $env:TEMP ('PostDeployVerify_'+$hn+'_'+$ts); New-Item -ItemType Directory -Path $work -Force | Out-Null; $log=Join-Path $work ('verify_'+$hn+'_'+$ts+'.log'); $sum=Join-Path $work ('summary_'+$hn+'_'+$ts+'.txt'); function Log($m){('[{0}] {1}' -f (Get-Date -Format 'yyyy-MM-dd HH:mm:ss'),$m) | Tee-Object -FilePath $log -Append | Out-Null}; $checks=New-Object System.Collections.Generic.List[object]; function AddCheck($name,$ok,$detail){$checks.Add([pscustomobject]@{Check=$name;OK=[bool]$ok;Detail=$detail})|Out-Null; Log(('{0}: {1} - {2}' -f $name,($(if($ok){'PASS'}else{'FAIL'})),$detail))}; Log('=== Post-Deployment Verifier شروع ==='); $isAdmin=$false; try{$isAdmin=([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)}catch{}; AddCheck 'RunningAsAdmin' $isAdmin ('Admin='+$isAdmin); try{ (Get-ComputerInfo | Select-Object CsName,OsName,OsVersion,WindowsVersion,OsBuildNumber,TimeZone,CsDomain,CsDomainRole | Format-List | Out-String) | Out-File (Join-Path $work 'computerinfo.txt') -Encoding UTF8 }catch{}; try{ $cs=Get-CimInstance Win32_ComputerSystem; $joined = -not [string]::IsNullOrWhiteSpace($cs.Domain) -and $cs.PartOfDomain; AddCheck 'DomainJoin' $joined ('Domain='+$cs.Domain+' PartOfDomain='+$cs.PartOfDomain) }catch{ AddCheck 'DomainJoin' $false 'Unable to query Win32_ComputerSystem' }; try{ $nl = (nltest /dsgetdc:$env:USERDNSDOMAIN) 2>&1 | Out-String; $ok = ($LASTEXITCODE -eq 0) -and ($nl -match 'DC:'); AddCheck 'DomainControllerDiscovery' $ok ('Exit='+$LASTEXITCODE); $nl | Out-File (Join-Path $work 'nltest_dsgetdc.txt') -Encoding UTF8 }catch{ AddCheck 'DomainControllerDiscovery' $false 'nltest failed' }; try{ $trust = (nltest /sc_verify:$env:USERDNSDOMAIN) 2>&1 | Out-String; $ok = ($LASTEXITCODE -eq 0) -and ($trust -match 'STATUS_SUCCESS'); AddCheck 'SecureChannel' $ok ('Exit='+$LASTEXITCODE); $trust | Out-File (Join-Path $work 'nltest_sc_verify.txt') -Encoding UTF8 }catch{ AddCheck 'SecureChannel' $false 'sc_verify failed' }; try{ $gp = (gpresult /R /SCOPE COMPUTER) 2>&1 | Out-String; $ok = ($LASTEXITCODE -eq 0) -and ($gp -match 'Applied Group Policy Objects'); AddCheck 'GPResultComputer' $ok ('Exit='+$LASTEXITCODE); $gp | Out-File (Join-Path $work 'gpresult_computer.txt') -Encoding UTF8 }catch{ AddCheck 'GPResultComputer' $false 'gpresult failed' }; try{ $gph = (gpresult /H (Join-Path $work 'gpresult.html')) 2>&1 | Out-String; AddCheck 'GPResultHTML' ($LASTEXITCODE -eq 0) ('Exit='+$LASTEXITCODE) }catch{ AddCheck 'GPResultHTML' $false 'gpresult /H failed' }; try{ $bl = Get-BitLockerVolume -ErrorAction Stop; $osv = $bl | Where-Object {$_.VolumeType -eq 'OperatingSystem'} | Select-Object -First 1; if($osv){ AddCheck 'BitLockerOS' ($osv.ProtectionStatus -eq 'On') ('Protection='+$osv.ProtectionStatus+' Status='+$osv.VolumeStatus) } else { AddCheck 'BitLockerOS' $false 'No OS volume found' }; ($bl | Format-List | Out-String) | Out-File (Join-Path $work 'bitlocker.txt') -Encoding UTF8 }catch{ AddCheck 'BitLockerOS' $false 'Get-BitLockerVolume not available or not permitted' }; try{ $sb = Confirm-SecureBootUEFI; AddCheck 'SecureBoot' ([bool]$sb) ('SecureBoot='+$sb) }catch{ AddCheck 'SecureBoot' $false 'Secure Boot query failed (BIOS/permissions)' }; try{ $fw = Get-NetFirewallProfile | Select Name,Enabled; $ok = ($fw | Where-Object {$_.Enabled -eq $false}).Count -eq 0; AddCheck 'FirewallProfilesEnabled' $ok (($fw | Format-Table -Auto | Out-String).Trim()); ($fw | Format-Table -Auto | Out-String) | Out-File (Join-Path $work 'firewall_profiles.txt') -Encoding UTF8 }catch{ AddCheck 'FirewallProfilesEnabled' $false 'Firewall profile query failed' }; try{ $av = Get-CimInstance -Namespace root/SecurityCenter2 -ClassName AntiVirusProduct | Select-Object displayName,productState,pathToSignedProductExe; $ok = ($av | Measure-Object).Count -ge 1; AddCheck 'AVRegistered' $ok ('Count='+($av | Measure-Object).Count); ($av | Format-List | Out-String) | Out-File (Join-Path $work 'av_status.txt') -Encoding UTF8 }catch{ AddCheck 'AVRegistered' $false 'SecurityCenter2 unavailable' }; try{ $svc = Get-Service -Name w32time -ErrorAction Stop; AddCheck 'TimeService' ($svc.Status -eq 'Running') ('Status='+$svc.Status+' StartType='+$svc.StartType); (w32tm /query /status) 2>&1 | Out-File (Join-Path $work 'w32tm_status.txt') -Encoding UTF8 }catch{ AddCheck 'TimeService' $false 'w32time query failed' }; try{ (ipconfig /all | Out-String) | Out-File (Join-Path $work 'ipconfig_all.txt') -Encoding UTF8; (route print | Out-String) | Out-File (Join-Path $work 'route_print.txt') -Encoding UTF8 }catch{}; try{ $apps = Get-ItemProperty HKLM:\Software\Microsoft\Windows\CurrentVersion\Uninstall\* -ErrorAction SilentlyContinue | Select-Object DisplayName,DisplayVersion,Publisher,InstallDate | Where-Object {$_.DisplayName} | Sort-Object DisplayName; ($apps | Format-Table -Auto | Out-String) | Out-File (Join-Path $work 'installed_software_hklm.txt') -Encoding UTF8 }catch{}; try{ $apps2 = Get-ItemProperty HKLM:\Software\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall\* -ErrorAction SilentlyContinue | Select-Object DisplayName,DisplayVersion,Publisher,InstallDate | Where-Object {$_.DisplayName} | Sort-Object DisplayName; ($apps2 | Format-Table -Auto | Out-String) | Out-File (Join-Path $work 'installed_software_wow6432.txt') -Encoding UTF8 }catch{}; $pass = ($checks | Where-Object {$_.OK -eq $false}).Count -eq 0; '=== POST-DEPLOYMENT SUMMARY ===' | Out-File $sum -Encoding UTF8; ('Host: {0}' -f $hn) | Out-File $sum -Append -Encoding UTF8; ('Time: {0}' -f $ts) | Out-File $sum -Append -Encoding UTF8; ('Overall: {0}' -f (if($pass){'PASS'}else{'FAIL'})) | Out-File $sum -Append -Encoding UTF8; '' | Out-File $sum -Append -Encoding UTF8; ($checks | Sort-Object Check | Format-Table -Auto | Out-String) | Out-File $sum -Append -Encoding UTF8; try{ $vol = Get-Volume | Where-Object {$_.FileSystemLabel -match 'BASHBUNNY|Bunny|USB'} | Select-Object -First 1; if($vol){ $dest = ('{0}:\loot\PostDeployVerify_{1}_{2}' -f $vol.DriveLetter,$hn,$ts); New-Item -ItemType Directory -Path $dest -Force | Out-Null; Copy-Item -Path (Join-Path $work '*') -Destination $dest -Recurse -Force; Log('Copied artifacts to: '+$dest); if($pass){ exit 0 } else { exit 2 } } else { Log('Bunny storage volume not found. Artifacts remain in: '+$work); if($pass){ exit 0 } else { exit 2 } } } catch { Log('Copy failed: '+$_.Exception.Message); if($pass){ exit 0 } else { exit 2 } }"
ENTER

REM Give it some time to finish on typical systems
DELAY 4000
LED GREEN
